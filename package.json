    "builtin-modules": "^5.2.0",
    "esbuild": "0.25.5",
    "eslint-plugin-obsidianmd": "0.1.9",
    "globals": "14.0.0",
    "jiti": "2.6.1",
    "tslib": "2.4.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "8.35.1"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "lunar-typescript": "^1.8.6",
    "obsidian": "1.10.3",
    "yaml": "^2.9.0"
